{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DFR Toolkit",
  "version": "0.1.3",
  "identifier": "com.dfr.toolkit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DFR Toolkit",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "dragDropEnabled": false,
        "fullscreen": false,
        "visible": false,
        "center": true
      },
      {
        "label": "splashscreen",
        "url": "splash.html",
        "title": "DFR Toolkit",
        "width": 440,
        "height": 220,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": true,
        "transparent": false,
        "shadow": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/seo-backend"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/CodeDFranky/seo-tool-2/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2RTZGNDUwQjhFRDhDNEMKUldSTWpPMjRVUFRtWmdETlRlSUJLKzhBdnNYa3I0L3RDM0N4MVNrcm50K2x0T3Z4YXBDVWRKMGEK"
    }
  }
}
